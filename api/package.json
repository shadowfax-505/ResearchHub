{
  "name": "researchhub-api",
  "version": "1.0.0",
  "description": "ResearchHub Academic Research Paper Repository API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "backup": "bash ../database/backup.sh",
    "setup": "npm install && npm run migrate && npm run seed"
  },
  "keywords": [
    "research",
    "papers",
    "academic",
    "repository",
    "database"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "serverless-http": "^3.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.48.0",
    "jest": "^29.6.4",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  }
}
